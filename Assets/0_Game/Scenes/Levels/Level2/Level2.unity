--- !u!102 &1966042319
TextMesh:
  serializedVersion: 3
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1966042318}
  m_Text: "IMPORTANT! READ THIS!\nTo achieve the same visuals as on the screenshots
    import Post-Processing Stack from Package Manager,\nset it up in your scene and
    use the Post Processing profile included in the Scenes folder.\n\nSetup:\n- Make
    sure your color space is set to Linear\n\n- After importing Post-Processing Stack,
    select Main Camera\nand add a new Layer (top right corner), name it PostProcessing\n\n-
    With camera selected, click Add Component and add Post-Process Layer\n\n- In
    Post-Process Layer switch Layer from Nothing to PostProcessing\n\n- Create a
    new empty game object and name it PostProcess Volume\n\n- Select it, change its
    layer to PostProcessing (top right corner)\n\n- Click Add Compoment and add Post-Process
    Volume\n\n- In Post-Process Volume component, turn on Is Global option and as
    Profile \nuse the included profile file from the Top Down - Common Files folder\n\n\n"
  m_OffsetZ: 0
  m_CharacterSize: 1
  m_LineSpacing: 1
  m_Anchor: 0
  m_Alignment: 0
  m_TabSize: 4
  m_FontSize: 30
  m_FontStyle: 0
  m_RichText: 1
  m_Font: {fileID: 10102, guid: 0000000000000000e000000000000000, type: 0}
  m_Color:
    serializedVersion: 2
    rgba: 4294967295
